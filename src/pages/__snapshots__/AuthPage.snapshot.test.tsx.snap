exports[`AuthPage — snapshot dos cartões de perfil > snapshot do HTML da grade de cartões (detecta mudanças de markup) 1`] = `"<div class="grid gap-4"><button data-profile-key="admin" aria-label="Entrar como Administrador. Aprova, controla e acompanha as OS." type="button" class="group relative flex items-center gap-4 p-5 rounded-2xl border-2 bg-card/90 backdrop-blur-sm transition-all duration-200 border-amber-500/40 hover:border-amber-400"><div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-amber-500/20 to-orange-500/20"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check h-6 w-6 text-amber-500"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path></svg></div><div class="text-left min-w-0"><h3 class="font-display font-semibold text-base text-foreground leading-tight">Entrar como Administrador</h3><p class="text-sm text-muted-foreground/80 mt-0.5">Aprova, controla e acompanha as OS.</p></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left ml-auto h-5 w-5 text-muted-foreground rotate-180 opacity-0 group-hover:opacity-100 transition-opacity shrink-0"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg></button><button data-profile-key="tecnico" aria-label="Entrar como Técnico. Orça, executa e finaliza o serviço." type="button" class="group relative flex items-center gap-4 p-5 rounded-2xl border-2 bg-card/90 backdrop-blur-sm transition-all duration-200 border-blue-500/40 hover:border-blue-400"><div class="flex h-12 w-12 shrink-0 items-